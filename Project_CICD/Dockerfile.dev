# Dockerfile.dev - สำหรับ Local Development (Clone แล้วรันได้เลย)
FROM php:8.1-fpm-alpine

# ติดตั้ง PHP Extensions + เครื่องมือที่จำเป็น
RUN apk add --no-cache \
    git curl zip unzip bash mysql-client \
    libzip-dev freetype libpng libjpeg-turbo \
    freetype-dev libpng-dev libjpeg-turbo-dev \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo_mysql gd zip \
    && apk del freetype-dev libpng-dev libjpeg-turbo-dev

# ติดตั้ง Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /var/www

# ก๊อปปี้ entrypoint script
COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 9000

# ใช้ entrypoint ที่จัดการทุกอย่างให้อัตโนมัติ
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
