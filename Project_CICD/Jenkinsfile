pipeline {
    agent any
    
    environment {
        // ใช้ชื่อโปรเจกต์ที่ไม่ซ้ำกัน เพื่อไม่ไปรบกวน Container dev ของเครื่องจริง
        COMPOSE_PROJECT_NAME = "ci_${BUILD_NUMBER}"
    }

    stages {
        stage('Prepare Code & Config') {
            steps {
                dir('Project_CICD') {
                    script {
                        echo "Preparing environment..."
                        sh "cp .env.example .env"
                    }
                }
            }
        }
        
        stage('Build & Start CI Environment') {
            steps {
                dir('Project_CICD') {
                    script {
                        // ลบ container เก่าที่อาจค้างอยู่
                        echo "Cleaning up any stale containers..."
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml down -v 2>/dev/null || true"
                        
                        echo "Building CI Docker images (code baked into image)..."
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml build"
                        
                        echo "Starting all services..."
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml up -d"
                        
                        echo "Waiting for services to stabilize (15 seconds)..."
                        sleep 15
                        
                        echo "=== Container Status ==="
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml ps"
                        
                        echo "=== Laravel Container Logs ==="
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml logs laravel.test || true"
                        
                        echo "Running database migrations..."
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml exec -T laravel.test php artisan migrate --force || echo 'Migration skipped'"
                    }
                }
            }
        }

        stage('Run Automated Tests') {
            steps {
                dir('Project_CICD') {
                    script {
                        // ====== 1. รัน Test ฝั่ง Laravel (PHP) ======
                        echo "Running PHPUnit Tests..."
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml exec -T laravel.test php artisan test"
                        
                        // ====== 2. รัน Test ฝั่ง .NET API ======
                        echo "Running .NET Tests..."
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml exec -T api_dotnet dotnet test || echo 'No .NET tests found, skipping...'"
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            when {
                branch 'main'
            }
            steps {
                dir('Project_CICD') {
                    script {
                        // ====== หยุด CI Environment ก่อน Deploy ======
                        echo "Stopping CI Environment before Production Deploy..."
                        sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml down -v --remove-orphans 2>/dev/null || true"
                        
                        // ====== สร้าง Docker Images สำหรับ K8s ======
                        echo "Building Docker Images for Kubernetes..."
                        sh "docker compose -p prod -f docker-compose.prod.yml build"
                        
                        // ====== อัปเดต K8s Manifests ======
                        echo "Deploying to Kubernetes Cluster..."
                        
                        // อ่านไฟล์ YAML จาก Jenkins แล้ว pipe เข้า kubectl ผ่าน stdin
                        // เพราะ volume mount จาก Jenkins container ไป kubectl container ใช้ไม่ได้ (DinD)
                        sh """
                        # 1. สร้าง Namespace ก่อนเป็นอันดับแรก
                        echo "Applying k8s/namespace.yaml ..."
                        cat k8s/namespace.yaml | docker run --rm -i \\
                            -v /c/Users/yanapat_sae/.kube/config:/.kube/config \\
                            --network host \\
                            -e KUBECONFIG=/.kube/config \\
                            bitnami/kubectl:latest apply -f -
                            
                        # 2. ค่อย Apply ไฟล์อื่นๆ ตามหลัง
                        for f in k8s/*.yaml; do
                            if [ "\$f" != "k8s/namespace.yaml" ]; then
                                echo "Applying \$f ..."
                                cat "\$f" | docker run --rm -i \\
                                    -v /c/Users/yanapat_sae/.kube/config:/.kube/config \\
                                    --network host \\
                                    -e KUBECONFIG=/.kube/config \\
                                    bitnami/kubectl:latest apply -f -
                            fi
                        done
                        """
                        
                        echo "Kubernetes Deployment Triggered Successfully."
                    }
                }
            }
        }
    }

    post {
        always {
            dir('Project_CICD') {
                script {
                    echo "Cleaning up CI Environment..."
                    sh "docker compose -p ${COMPOSE_PROJECT_NAME} -f compose.ci.yml down -v --remove-orphans 2>/dev/null || true"
                }
            }
        }
        success {
            echo "CI/CD Pipeline Completed Successfully!"
        }
        failure {
            echo "CI/CD Pipeline Failed! Please check the logs."
        }
    }
}
